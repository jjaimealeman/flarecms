  /* KV — 2% later (~160ms) */
  @keyframes flow-glow-3c {
    0%, 38% { box-shadow: none; transform: scale(1); }
    40%, 44% { box-shadow: 0 0 14px currentColor; transform: scale(1.1); }
    48%, 100% { box-shadow: none; transform: scale(1); }
  }
  @keyframes flow-glow-bubble {
    0%, 36% { opacity: 0.6; border-color: var(--color-border); }
    38%, 42% { opacity: 1; border-color: var(--color-text-tertiary); }
    46%, 100% { opacity: 0.6; border-color: var(--color-border); }
  }
</style>

<script>
  const tile = document.getElementById('admin-ui-tile')
  if (tile) {
    const videos = tile.querySelectorAll('.bento-video')
    tile.addEventListener('mouseenter', () => {
      videos.forEach(v => (v as HTMLVideoElement).pause())
    })
    tile.addEventListener('mouseleave', () => {
      videos.forEach(v => (v as HTMLVideoElement).play())
    })
  }

  // Orbit definition labels — cycle in sync with 18s orbit
  // D1 at bottom: 4.5s, KV at bottom: 10.5s, R2 at bottom: 16.5s
  const defs = document.querySelectorAll('.orbit-def') as NodeListOf<HTMLElement>
  if (defs.length === 3) {
    const order = [0, 2, 1] // d1, kv, r2 — order they reach bottom
    let active = -1

    function showDef(idx: number) {
      defs.forEach(d => d.style.opacity = '0')
      defs[order[idx]].style.opacity = '1'
      active = idx
    }

    // First label appears at 1.5s (D1 approaching bottom)
    setTimeout(() => {
      showDef(0)
      setInterval(() => {
        showDef((active + 1) % 3)
      }, 6000)
    }, 1500)
  }
</script>
