---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Documentation">
  <div class="max-w-3xl mx-auto px-6 pt-12 pb-20">
    <header class="mb-12">
      <h1 class="text-4xl font-heading font-bold tracking-tight">Documentation</h1>
      <p class="mt-4 text-slate-400 text-lg leading-relaxed">
        Flare CMS documentation is coming soon. In the meantime, check out the
        <a href="https://github.com/jjaimealeman/flarecms" class="text-flare-400 hover:text-flare-300 transition-colors">GitHub repository</a>
        for setup instructions.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <a href="https://github.com/jjaimealeman/flarecms#readme" class="group block p-6 rounded-xl border border-slate-800 bg-slate-800/30 hover:bg-slate-800/60 hover:border-slate-700 transition-all">
        <h3 class="font-heading font-semibold text-slate-50 group-hover:text-flare-400 transition-colors">Quick Start</h3>
        <p class="mt-2 text-sm text-slate-400">Clone, install, and run your first Flare CMS instance.</p>
      </a>
      <a href="https://github.com/jjaimealeman/flarecms/tree/main/packages/core" class="group block p-6 rounded-xl border border-slate-800 bg-slate-800/30 hover:bg-slate-800/60 hover:border-slate-700 transition-all">
        <h3 class="font-heading font-semibold text-slate-50 group-hover:text-flare-400 transition-colors">Core Package</h3>
        <p class="mt-2 text-sm text-slate-400">The engine — collections, API routes, admin UI, and database.</p>
      </a>
      <a href="https://github.com/jjaimealeman/flarecms/tree/main/packages/cms" class="group block p-6 rounded-xl border border-slate-800 bg-slate-800/30 hover:bg-slate-800/60 hover:border-slate-700 transition-all">
        <h3 class="font-heading font-semibold text-slate-50 group-hover:text-flare-400 transition-colors">CMS Backend</h3>
        <p class="mt-2 text-sm text-slate-400">Cloudflare Worker with D1, R2, and collection configs.</p>
      </a>
      <a href="https://github.com/jjaimealeman/flarecms/tree/main/packages/site" class="group block p-6 rounded-xl border border-slate-800 bg-slate-800/30 hover:bg-slate-800/60 hover:border-slate-700 transition-all">
        <h3 class="font-heading font-semibold text-slate-50 group-hover:text-flare-400 transition-colors">Astro Frontend</h3>
        <p class="mt-2 text-sm text-slate-400">SSR site on Cloudflare Pages consuming the CMS API.</p>
      </a>
    </div>
  </div>
</Layout>
