---
import { getBlogPosts } from '../../lib/flare';
import Layout from '../../layouts/Layout.astro';

const posts = await getBlogPosts();
---

<Layout title="Blog">
  <div class="max-w-5xl mx-auto px-6 pt-12 pb-20">
    <header class="mb-12">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900">Blog</h1>
      <p class="mt-2 text-gray-600">Thoughts, guides, and updates from the edge.</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <a href={`/blog/${post.data.slug}`} class="group block">
          <article class="h-full bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg hover:border-gray-300 transition-all duration-200">
            {post.data.featuredImage && (
              <img
                src={post.data.featuredImage}
                alt={post.data.title}
                loading="lazy"
                class="w-full h-48 object-cover"
              />
            )}
            <div class="p-5">
              <h2 class="font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors">
                {post.data.title}
              </h2>
              {post.data.excerpt && (
                <p class="mt-2 text-sm text-gray-600 line-clamp-2">{post.data.excerpt}</p>
              )}
              {post.data.publishedAt && (
                <time datetime={post.data.publishedAt} class="mt-3 block text-xs text-gray-400">
                  {new Date(post.data.publishedAt).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric'
                  })}
                </time>
              )}
            </div>
          </article>
        </a>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-20">
        <p class="text-gray-500">No published posts yet.</p>
      </div>
    )}
  </div>
</Layout>
