  /* ---- Request flow diagram ---- */
  .flow-scene {
    position: relative;
    height: 180px;
  }

  /* Layer 1: Lines (z-index 1), Layer 2: Dot (z-index 2), Layer 3: Nodes (z-index 3) */

  /* Dashed lines — horizontal and vertical */
  .flow-line-h, .flow-line-v {
    position: absolute;
    border-color: var(--color-border);
    z-index: 1;
  }

  .flow-line-h {
    height: 0;
    border-top: 1.5px dashed var(--color-border);
  }

  .flow-line-v {
    width: 0;
    border-left: 1.5px dashed var(--color-border);
  }

  /* Path labels — crossfade synced to 8s dot loop */
  .flow-path-label {
    position: absolute;
    font-size: 11px;
    color: var(--color-text-tertiary);
    letter-spacing: 0.03em;
    z-index: 0;
  }

  /* "request →" visible during forward trip (0-38%), hidden during return */
  .flow-label-request {
    animation: flow-label-req 8s linear infinite;
  }

  /* "← response" visible during return trip (46-92%), hidden during forward */
  .flow-label-response {
    animation: flow-label-res 8s linear infinite;
  }

  @keyframes flow-label-req {
    0%, 4% { opacity: 0; }
    6%, 34% { opacity: 1; }
    40%, 100% { opacity: 0; }
  }

  @keyframes flow-label-res {
    0%, 44% { opacity: 0; }
    50%, 86% { opacity: 1; }
    92%, 100% { opacity: 0; }
  }

  /* Nodes */
  .flow-node {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    z-index: 3;
    transform: translateX(-50%);
