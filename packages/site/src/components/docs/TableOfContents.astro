---
interface Props {
  headings: Array<{ id: string; text: string; level: number }>
}

const { headings } = Astro.props
---

{headings.length > 0 && (
  <div>
    <p class="text-xs uppercase tracking-wider text-slate-500 mb-3">On this page</p>
    <nav>
      <ul class="space-y-0">
        {headings.map((h) => (
          <li class="py-1">
            <a
              data-toc-link={h.id}
              href={`#${h.id}`}
              class:list={[
                'block transition-colors',
                h.level === 3 ? 'pl-3 text-xs text-slate-500 hover:text-slate-300' : 'text-sm text-slate-400 hover:text-slate-200',
              ]}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
)}
