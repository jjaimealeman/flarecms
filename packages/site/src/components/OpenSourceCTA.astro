<section class="py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="relative rounded-2xl border border-slate-700/50 bg-gradient-to-b from-slate-800/80 to-slate-900/80 overflow-hidden">
      <!-- Subtle glow -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-48 bg-flare-500/10 blur-3xl rounded-full"></div>

      <div class="relative text-center py-20 px-8">
        <h2 class="text-3xl font-heading font-bold tracking-tight">
          Built by the community, for the web.
        </h2>
        <p class="mt-4 text-slate-400 max-w-xl mx-auto">
          Flare CMS is 100% open-source and will always be. Join our growing community
          of developers building the future of content management.
        </p>

        <div class="mt-8 flex items-center justify-center gap-4">
          <a
            href="https://github.com/jjaimealeman/flarecms"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 bg-slate-50 hover:bg-white text-slate-900 text-sm font-semibold rounded-lg transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
            Star on GitHub
          </a>
          <a
            href="/docs"
            class="inline-flex items-center gap-2 px-6 py-3 border border-slate-600 hover:border-slate-500 text-slate-300 hover:text-slate-50 text-sm font-medium rounded-lg transition-all"
          >
            Read Documentation
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
