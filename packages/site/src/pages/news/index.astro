---
import { getNewsArticles } from '../../lib/flare'
import Layout from '../../layouts/Layout.astro'

let articles: any[] = []
try {
  articles = await getNewsArticles()
} catch {
  // CMS API unavailable
}

const categoryStyles: Record<string, string> = {
  technology: 'bg-cyan-500/10 text-cyan-400',
  business: 'bg-amber-500/10 text-amber-400',
  general: 'bg-slate-700 text-slate-300',
}
---

<Layout title="News">
  <div class="max-w-5xl mx-auto px-6 pt-12 pb-20">
    <header class="mb-12">
      <h1 class="text-4xl font-heading font-bold tracking-tight">News</h1>
      <p class="mt-2 text-slate-400">Technology, business, and community updates.</p>
    </header>

    <div class="space-y-4">
      {articles.map((article) => (
        <a href={`/news/${article.slug}`} class="group block">
          <article class="rounded-xl border border-slate-800 bg-slate-800/30 hover:bg-slate-800/60 hover:border-slate-700 transition-all p-6">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  {article.data.category && (
                    <span class:list={[
                      'inline-block px-2.5 py-0.5 rounded-md text-xs font-medium',
                      categoryStyles[article.data.category] || 'bg-slate-700 text-slate-300'
                    ]}>
                      {article.data.category}
                    </span>
                  )}
                  {article.data.publish_date && (
                    <time datetime={article.data.publish_date} class="text-xs text-slate-500">
                      {new Date(article.data.publish_date).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'short',
                        day: 'numeric'
                      })}
                    </time>
                  )}
                </div>
                <h2 class="font-heading font-semibold text-lg text-slate-50 group-hover:text-flare-400 transition-colors">
                  {article.data.title}
                </h2>
                {article.data.author && (
                  <p class="mt-1 text-sm text-slate-500">By {article.data.author}</p>
                )}
              </div>
              <span class="text-slate-600 group-hover:text-flare-500 transition-colors mt-1 shrink-0">
                &rarr;
              </span>
            </div>
          </article>
        </a>
      ))}
    </div>

    {articles.length === 0 && (
      <div class="text-center py-20">
        <p class="text-slate-500">No news articles yet.</p>
      </div>
    )}
  </div>
</Layout>
