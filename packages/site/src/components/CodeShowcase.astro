---
import { codeSchema, codeResponse } from '../data/homepage'
---

<section class="py-24 border-t border-border">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold tracking-tight">
        Define your schema. Fetch it anywhere.
      </h2>
      <p class="mt-4 text-slate-400 max-w-2xl mx-auto">
        Collections are TypeScript objects with typed fields. The API is generated automatically.
      </p>
    </div>

    <div class="relative grid grid-cols-[1fr,auto,1fr] gap-6 items-start">
      <!-- Left: Schema definition -->
      <div>
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm text-slate-400 font-mono">blog-posts.collection.ts</span>
          <span class="text-xs font-medium text-cyan-400 uppercase tracking-wider">Schema</span>
        </div>
        <div class="rounded-xl border border-slate-700/50 bg-slate-950 overflow-hidden">
          <div class="p-5 font-mono text-sm leading-7 overflow-x-auto">
            <pre class="text-slate-300"><code set:html={
              codeSchema
                .replace(/import type/g, '<span class="text-flare-400">import type</span>')
                .replace(/from/g, '<span class="text-flare-400">from</span>')
                .replace(/export default/g, '<span class="text-flare-400">export default</span>')
                .replace(/satisfies CollectionConfig/g, '<span class="text-cyan-400">satisfies CollectionConfig</span>')
                .replace(/'([^']*)'/g, '<span class="text-emerald-400">\'$1\'</span>')
                .replace(/\b(true)\b/g, '<span class="text-amber-400">$1</span>')
                .replace(/\b(type|name|displayName|schema|properties|title|content|slug|featuredImage|required|listFields|defaultSort|defaultSortOrder)\b(?=:)/g, '<span class="text-slate-400">$1</span>')
            } /></pre>
          </div>
        </div>
      </div>

      <!-- Arrow connector -->
      <div class="flex flex-col items-center justify-center pt-12 gap-2">
        <div class="w-12 h-12 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center shadow-lg shadow-flare-500/5">
          <svg class="w-5 h-5 text-flare-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14m-7-7 7 7-7 7" />
          </svg>
        </div>
        <span class="text-[10px] text-slate-600 uppercase tracking-widest">API</span>
      </div>

      <!-- Right: API response -->
      <div>
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm text-slate-400 font-mono">GET /api/collections/blog-posts/content</span>
          <span class="text-xs font-medium text-amber-400 uppercase tracking-wider">Response</span>
        </div>
        <div class="rounded-xl border border-slate-700/50 bg-slate-950 overflow-hidden">
          <div class="p-5 font-mono text-sm leading-7 overflow-x-auto">
            <pre class="text-slate-300"><code set:html={
              codeResponse
                .replace(/^(GET .+)$/m, '<span class="text-slate-500">$1</span>\n')
                .replace(/"(\w+)"(?=\s*:)/g, '<span class="text-cyan-400">"$1"</span>')
                .replace(/: "([^"]*)"/g, ': <span class="text-emerald-400">"$1"</span>')
                .replace(/: (true|false)/g, ': <span class="text-amber-400">$1</span>')
                .replace(/: (\d+)/g, ': <span class="text-flare-400">$1</span>')
            } /></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
