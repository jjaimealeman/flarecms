---
const terminalLines = [
  { prompt: true, text: 'git clone https://github.com/jjaimealeman/flarecms' },
  { prompt: true, text: 'cd flarecms && pnpm install' },
  { prompt: false, text: '' },
  { prompt: false, text: '✔ Packages installed (3 workspaces)' },
  { prompt: false, text: '' },
  { prompt: true, text: 'pnpm build' },
  { prompt: false, text: '✔ @flare-cms/core built (8 entry points)' },
  { prompt: false, text: '' },
  { prompt: true, text: 'cd packages/cms && wrangler dev' },
  { prompt: false, text: '⚡ Listening on http://localhost:8787' },
  { prompt: false, text: '⚡ Admin UI → http://localhost:8787/admin' },
  { prompt: false, text: '⚡ API docs → http://localhost:8787/docs' },
]
---

<section class="relative overflow-hidden">
  <!-- Subtle grid pattern background -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(246,130,31,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(246,130,31,0.03)_1px,transparent_1px)] bg-[size:64px_64px]"></div>

  <div class="relative max-w-7xl mx-auto px-6 pt-24 pb-20">
    <div class="grid grid-cols-2 gap-16 items-center">
      <!-- Left: Copy -->
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-flare-500/10 border border-flare-500/20 text-flare-400 text-xs font-medium mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          v1.0 is live
        </div>

        <h1 class="text-6xl font-heading font-bold tracking-tight leading-[1.1]">
          Content at the
          <span class="bg-gradient-to-r from-flare-500 to-cyan-400 bg-clip-text text-transparent">edge</span>.
        </h1>

        <p class="mt-6 text-lg text-slate-400 leading-relaxed max-w-lg">
          Open-source headless CMS built on Cloudflare Workers, D1, and R2. Deploy globally in seconds, scale infinitely with zero cold starts.
        </p>

        <div class="mt-8 flex items-center gap-4">
          <a
            href="/docs"
            class="inline-flex items-center gap-2 px-6 py-3 bg-flare-500 hover:bg-flare-400 text-slate-950 text-sm font-semibold rounded-lg transition-colors"
          >
            Read the Docs
          </a>
          <a
            href="https://github.com/jjaimealeman/flarecms"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 border border-slate-700 hover:border-slate-500 text-slate-300 hover:text-slate-50 text-sm font-medium rounded-lg transition-all"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
        </div>

        <!-- Trust badges -->
        <div class="mt-10 flex items-center gap-6 text-xs text-slate-500">
          <span class="flex items-center gap-1.5">
            <span class="w-1 h-1 rounded-full bg-flare-500"></span>
            Cloudflare Workers
          </span>
          <span class="flex items-center gap-1.5">
            <span class="w-1 h-1 rounded-full bg-cyan-500"></span>
            Astro Frontend
          </span>
          <span class="flex items-center gap-1.5">
            <span class="w-1 h-1 rounded-full bg-emerald-500"></span>
            MIT License
          </span>
          <span class="flex items-center gap-1.5">
            <span class="w-1 h-1 rounded-full bg-amber-500"></span>
            TypeScript
          </span>
        </div>
      </div>

      <!-- Right: Terminal mockup -->
      <div class="relative">
        <div class="rounded-xl border border-slate-700/50 bg-slate-950 shadow-2xl shadow-flare-500/5 overflow-hidden">
          <!-- Terminal header -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-slate-800 bg-slate-900/50">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-slate-700"></div>
              <div class="w-3 h-3 rounded-full bg-slate-700"></div>
              <div class="w-3 h-3 rounded-full bg-slate-700"></div>
            </div>
            <span class="text-xs text-slate-500 font-mono ml-2">terminal — zsh</span>
          </div>

          <!-- Terminal content -->
          <div class="p-5 font-mono text-sm leading-7">
            {terminalLines.map((line) => (
              <div class:list={[
                line.prompt ? 'text-slate-200' : 'text-slate-500',
              ]}>
                {line.prompt && <span class="text-flare-500">$ </span>}
                {line.text ? (
                  <span set:html={
                    line.text
                      .replace(/flarecms/g, '<span class="text-flare-400">flarecms</span>')
                      .replace(/pnpm (install|build)/g, 'pnpm <span class="text-cyan-400">$1</span>')
                      .replace(/wrangler dev/g, '<span class="text-amber-400">wrangler dev</span>')
                      .replace(/✔/g, '<span class="text-emerald-400">✔</span>')
                      .replace(/⚡/g, '<span class="text-amber-400">⚡</span>')
                      .replace(/(http:\/\/localhost:\d+\S*)/g, '<span class="text-cyan-400">$1</span>')
                      .replace(/@flare-cms\/core/g, '<span class="text-flare-400">@flare-cms/core</span>')
                      .replace(/git clone/g, '<span class="text-slate-400">git clone</span>')
                  } />
                ) : (
                  <br />
                )}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
