---
import { codeSchema } from '../data/homepage'
---

<section class="py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="text-xs text-cyan-400 uppercase tracking-widest font-medium">Why Flare CMS</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight">
        Everything you need at the edge
      </h2>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <!-- Admin UI screenshot (span 2 cols, tall) -->
      <div class="md:col-span-2 md:row-span-2 rounded-2xl border border-border bg-surface-secondary overflow-hidden group">
        <div class="p-6 pb-0">
          <h3 class="font-semibold text-text-primary mb-1">Built-in Admin UI</h3>
          <p class="text-sm text-text-secondary">Content management, media library, and user management out of the box.</p>
        </div>
        <div class="mt-4 mx-6 rounded-t-xl border border-b-0 border-border overflow-hidden bg-surface-tertiary">
          <video
            autoplay
            loop
            muted
            playsinline
            class="w-full h-auto opacity-90 group-hover:opacity-100 transition-opacity dark-only"
          >
            <source src="/videos/flare-demo-dark.mp4" type="video/mp4" />
          </video>
          <video
            autoplay
            loop
            muted
            playsinline
            class="w-full h-auto opacity-90 group-hover:opacity-100 transition-opacity light-only hidden"
          >
            <source src="/videos/flare-demo-light.mp4" type="video/mp4" />
          </video>
        </div>
      </div>

      <!-- Performance stat -->
      <div class="rounded-2xl border border-border bg-surface-secondary p-8 flex flex-col items-center justify-center text-center">
        <div class="text-5xl font-bold text-flare-500 mb-2">330+</div>
        <div class="text-sm text-text-secondary">Edge locations worldwide</div>
        <div class="mt-3 text-xs text-text-tertiary">Sub-50ms latency globally</div>
      </div>

      <!-- Zero cold starts -->
      <div class="rounded-2xl border border-border bg-surface-secondary p-8 flex flex-col items-center justify-center text-center">
        <div class="text-5xl font-bold text-cyan-400 mb-2">0</div>
        <div class="text-sm text-text-secondary">Cold starts</div>
        <div class="mt-3 text-xs text-text-tertiary">Always warm, always fast</div>
      </div>

      <!-- Code snippet tile (schema definition) -->
      <div class="rounded-2xl border border-border bg-surface-secondary overflow-hidden">
        <div class="p-5 pb-3">
          <div class="flex items-center justify-between">
            <h3 class="font-semibold text-text-primary text-sm">Type-safe Collections</h3>
            <span class="text-[10px] font-medium text-cyan-400 uppercase tracking-wider">Schema</span>
          </div>
        </div>
        <div class="px-5 pb-5">
          <div class="rounded-lg bg-surface-primary border border-border p-4 font-mono text-[11px] leading-5 overflow-x-auto text-text-secondary">
            <pre><code set:html={
              codeSchema
                .split('\n').slice(0, 12).join('\n')
                .replace(/import type/g, '<span class="text-flare-400">import type</span>')
                .replace(/from/g, '<span class="text-flare-400">from</span>')
                .replace(/export default/g, '<span class="text-flare-400">export default</span>')
                .replace(/'([^']*)'/g, '<span class="text-emerald-400">\'$1\'</span>')
                .replace(/\b(true)\b/g, '<span class="text-amber-400">$1</span>')
            } /></pre>
          </div>
        </div>
      </div>

      <!-- Plugin architecture (span 2 cols) -->
      <div class="md:col-span-2 rounded-2xl border border-border bg-surface-secondary p-8">
        <h3 class="font-semibold text-text-primary mb-2">Plugin Architecture</h3>
        <p class="text-sm text-text-secondary mb-6">Extend with custom fields, hooks, and middleware. Ship features as portable plugins.</p>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="flex flex-col items-center gap-2 p-4 rounded-xl bg-surface-tertiary border border-border">
            <svg class="w-6 h-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <ellipse cx="12" cy="5" rx="9" ry="3" /><path d="M3 5V19A9 3 0 0 0 21 19V5" /><path d="M3 12A9 3 0 0 0 21 12" />
            </svg>
            <span class="text-xs text-text-secondary font-medium">D1 Database</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-4 rounded-xl bg-surface-tertiary border border-border">
            <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242" /><path d="M12 12v9" /><path d="m8 17 4 4 4-4" />
            </svg>
            <span class="text-xs text-text-secondary font-medium">R2 Storage</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-4 rounded-xl bg-surface-tertiary border border-border">
            <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
            <span class="text-xs text-text-secondary font-medium">KV Cache</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-4 rounded-xl bg-surface-tertiary border border-border">
            <svg class="w-6 h-6 text-flare-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M19.439 7.85c-.049.322.059.648.289.878l1.568 1.568c.47.47.706 1.087.706 1.704s-.235 1.233-.706 1.704l-1.611 1.611a.98.98 0 0 1-.837.276c-.47-.07-.802-.48-.968-.925a2.501 2.501 0 1 0-3.214 3.214c.446.166.855.497.925.968a.979.979 0 0 1-.276.837l-1.61 1.61a2.404 2.404 0 0 1-1.705.707 2.402 2.402 0 0 1-1.704-.706l-1.568-1.568a1.026 1.026 0 0 0-.877-.29c-.493.074-.84.504-1.02.968a2.5 2.5 0 1 1-3.237-3.237c.464-.18.894-.527.967-1.02a1.026 1.026 0 0 0-.289-.877l-1.568-1.568A2.402 2.402 0 0 1 1.998 12c0-.617.236-1.234.706-1.704L4.315 8.685a.98.98 0 0 1 .837-.276c.47.07.802.48.968.925a2.501 2.501 0 1 0 3.214-3.214c-.446-.166-.855-.497-.925-.968a.979.979 0 0 1 .276-.837l1.61-1.61a2.404 2.404 0 0 1 1.705-.707c.617 0 1.234.236 1.704.706l1.568 1.568c.23.23.556.338.877.29.493-.074.84-.504 1.02-.968a2.5 2.5 0 1 1 3.237 3.237c-.464.18-.894.527-.967 1.02z" />
            </svg>
            <span class="text-xs text-text-secondary font-medium">Plugins</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
