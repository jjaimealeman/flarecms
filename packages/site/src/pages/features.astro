---
import Layout from '../layouts/Layout.astro'
import {
  differentiators,
  coreFeatures,
  aiSearchDetails,
  analyticsComparison,
  analyticsTracking,
  roadmap,
} from '../data/features'

const statusBadge: Record<string, { label: string; classes: string }> = {
  stable: { label: 'Stable', classes: 'bg-emerald-500/15 text-emerald-400 border-emerald-500/30' },
  beta: { label: 'Beta', classes: 'bg-amber-500/15 text-amber-400 border-amber-500/30' },
  'coming-soon': { label: 'Coming Soon', classes: 'bg-purple-500/15 text-purple-400 border-purple-500/30' },
}

const iconColorMap: Record<string, string> = {
  flare: 'text-flare-500 bg-flare-500/15',
  cyan: 'text-cyan-400 bg-cyan-500/15',
  purple: 'text-purple-400 bg-purple-500/15',
  emerald: 'text-emerald-400 bg-emerald-500/15',
  amber: 'text-amber-400 bg-amber-500/15',
  rose: 'text-rose-400 bg-rose-500/15',
  blue: 'text-blue-400 bg-blue-500/15',
}
---

<Layout title="Features" description="Everything Flare CMS offers — edge-native performance, Astro integration, 15 plugins, AI search, built-in analytics, and more.">
  <div class="max-w-7xl mx-auto px-6 pt-16 pb-24">

    <!-- Header -->
    <header class="text-center mb-20">
      <span class="text-xs text-flare-400 uppercase tracking-widest font-medium">Features</span>
      <h1 class="mt-3 text-4xl sm:text-5xl font-sans font-bold tracking-tight">
        Everything you need,<br class="hidden sm:block" /> nothing you don't
      </h1>
      <p class="mt-4 text-lg text-slate-400 max-w-2xl mx-auto">
        A headless CMS that ships with batteries included. Edge-native performance, full Astro DX, and a plugin system that actually works.
      </p>
    </header>

    <!-- === Top 3 Differentiators === -->
    <section class="mb-24">
      <div class="grid md:grid-cols-3 gap-6">
        {differentiators.map((d) => (
          <div class="relative rounded-2xl border border-slate-800 bg-gradient-to-b from-slate-800/50 to-transparent p-8 hover:border-slate-700 transition-colors">
            <div class:list={['w-12 h-12 rounded-xl flex items-center justify-center mb-5', iconColorMap[d.color]]}>
              {d.icon === 'astro' && (
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" />
                </svg>
              )}
              {d.icon === 'edge' && (
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <circle cx="12" cy="12" r="10" /><path d="M2 12h20" /><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                </svg>
              )}
              {d.icon === 'plugins' && (
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M19.439 7.85c-.049.322.059.648.289.878l1.568 1.568c.47.47.706 1.087.706 1.704s-.235 1.233-.706 1.704l-1.611 1.611a.98.98 0 0 1-.837.276c-.47-.07-.802-.48-.968-.925a2.501 2.501 0 1 0-3.214 3.214c.446.166.855.497.925.968a.979.979 0 0 1-.276.837l-1.61 1.61a2.404 2.404 0 0 1-1.705.707 2.402 2.402 0 0 1-1.704-.706l-1.568-1.568a1.026 1.026 0 0 0-.877-.29c-.493.074-.84.504-1.02.968a2.5 2.5 0 1 1-3.237-3.237c.464-.18.894-.527.967-1.02a1.026 1.026 0 0 0-.289-.877l-1.568-1.568A2.402 2.402 0 0 1 1.998 12c0-.617.236-1.234.706-1.704L4.315 8.685a.98.98 0 0 1 .837-.276c.47.07.802.48.968.925a2.501 2.501 0 1 0 3.214-3.214c-.446-.166-.855-.497-.925-.968a.979.979 0 0 1 .276-.837l1.61-1.61a2.404 2.404 0 0 1 1.705-.707c.617 0 1.234.236 1.704.706l1.568 1.568c.23.23.556.338.877.29.493-.074.84-.504 1.02-.968a2.5 2.5 0 1 1 3.237 3.237c-.464.18-.894.527-.967 1.02z" />
                </svg>
              )}
            </div>
            <h3 class="text-xl font-sans font-bold text-slate-50 mb-3">{d.title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{d.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- === Core Features Grid === -->
    <section class="mb-24">
      <div class="text-center mb-12">
        <span class="text-xs text-cyan-400 uppercase tracking-widest font-medium">Core Features</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-sans font-bold tracking-tight">
          Ship faster with batteries included
        </h2>
        <p class="mt-3 text-slate-400 max-w-xl mx-auto">
          Every feature you'd expect from a modern CMS — plus a few you wouldn't.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {coreFeatures.map((feature) => {
          const badge = feature.status ? statusBadge[feature.status] : null
          return (
            <div class="group p-6 rounded-xl border border-slate-800 bg-slate-800/30 hover:bg-slate-800/50 hover:border-slate-700 transition-all">
              <div class="flex items-start justify-between mb-4">
                <div class:list={['w-10 h-10 rounded-lg flex items-center justify-center', iconColorMap[feature.color]]}>
                  {feature.icon === 'layout-dashboard' && (
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="3" width="7" height="9" rx="1" /><rect x="14" y="3" width="7" height="5" rx="1" /><rect x="14" y="12" width="7" height="9" rx="1" /><rect x="3" y="16" width="7" height="5" rx="1" />
                    </svg>
                  )}
                  {feature.icon === 'file-text' && (
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><polyline points="10 9 9 9 8 9" />
                    </svg>
                  )}
                  {feature.icon === 'workflow' && (
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="3" width="6" height="6" rx="1" /><rect x="15" y="3" width="6" height="6" rx="1" /><rect x="9" y="15" width="6" height="6" rx="1" /><path d="M6 9v3a1 1 0 0 0 1 1h4" /><path d="M18 9v3a1 1 0 0 1-1 1h-4" />
                    </svg>
                  )}
                  {feature.icon === 'image' && (
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" /><polyline points="21 15 16 10 5 21" />
                    </svg>
                  )}
                  {feature.icon === 'file-input' && (
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path d="M4 22h14a2 2 0 0 0 2-2V7.5L14.5 2H6a2 2 0 0 0-2 2v4" /><polyline points="14 2 14 8 20 8" /><path d="M2 15h10" /><path d="m9 18 3-3-3-3" />
                    </svg>
                  )}
                  {feature.icon === 'mail' && (
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                  )}
                  {feature.icon === 'key' && (
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4" />
                    </svg>
                  )}
                  {feature.icon === 'book-open' && (
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" /><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                    </svg>
                  )}
                  {feature.icon === 'shield' && (
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                    </svg>
                  )}
                  {feature.icon === 'database' && (
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <ellipse cx="12" cy="5" rx="9" ry="3" /><path d="M3 5V19A9 3 0 0 0 21 19V5" /><path d="M3 12A9 3 0 0 0 21 12" />
                    </svg>
                  )}
                  {feature.icon === 'code' && (
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" />
                    </svg>
                  )}
                  {feature.icon === 'webhook' && (
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path d="M18 16.98h-5.99c-1.1 0-1.95.94-2.48 1.9A4 4 0 0 1 2 17c.01-.7.2-1.4.57-2" /><path d="m6 17 3.13-5.78c.53-.97.1-2.18-.5-3.1a4 4 0 1 1 6.89-4.06" /><path d="m12 6 3.13 5.73C15.66 12.7 16.9 13 18 13a4 4 0 0 1 0 8H12" />
                    </svg>
                  )}
                </div>
                {badge && (
                  <span class:list={['text-[10px] font-medium px-2 py-0.5 rounded-full border', badge.classes]}>
                    {badge.label}
                  </span>
                )}
              </div>
              <h3 class="font-sans font-semibold text-slate-50 mb-2">{feature.title}</h3>
              <p class="text-sm text-slate-400 leading-relaxed">{feature.description}</p>
            </div>
          )
        })}
      </div>
    </section>

    <!-- === AI Search Spotlight === -->
    <section class="mb-24">
      <div class="rounded-2xl border border-cyan-500/20 bg-gradient-to-br from-cyan-500/5 to-transparent p-8 sm:p-12">
        <div class="flex items-start justify-between mb-6">
          <div>
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg bg-cyan-500/15 flex items-center justify-center">
                <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <circle cx="11" cy="11" r="8" /><path d="m21 21-4.35-4.35" /><path d="M11 8v6" /><path d="M8 11h6" />
                </svg>
              </div>
              <h2 class="text-2xl sm:text-3xl font-sans font-bold tracking-tight">{aiSearchDetails.title}</h2>
            </div>
            <span class:list={['text-[10px] font-medium px-2 py-0.5 rounded-full border', statusBadge.beta.classes]}>
              Beta
            </span>
          </div>
        </div>
        <p class="text-slate-400 mb-8 max-w-2xl">{aiSearchDetails.description}</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {aiSearchDetails.capabilities.map((cap) => (
            <div class="flex items-center gap-3 text-sm">
              <svg class="w-4 h-4 text-cyan-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <span class="text-slate-300">{cap}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- === Analytics Comparison === -->
    <section class="mb-24">
      <div class="text-center mb-12">
        <span class="text-xs text-emerald-400 uppercase tracking-widest font-medium">Built-in Analytics</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-sans font-bold tracking-tight">
          Analytics without the baggage
        </h2>
        <p class="mt-3 text-slate-400 max-w-xl mx-auto">
          Privacy-first, edge-computed analytics built directly into your CMS. No cookie banners, no external scripts, no additional cost.
        </p>
        <span class:list={['inline-block mt-3 text-[10px] font-medium px-2 py-0.5 rounded-full border', statusBadge['stable'].classes]}>
          Built In
        </span>
      </div>

      <!-- What we'll track -->
      <div class="mb-10">
        <h3 class="text-lg font-sans font-semibold text-slate-200 mb-4">What gets tracked</h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
          {analyticsTracking.map((item) => (
            <div class="flex items-center gap-2.5 text-sm">
              <svg class="w-3.5 h-3.5 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <span class="text-slate-400">{item}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Comparison table -->
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-slate-800">
              <th class="text-left py-3 px-4 font-medium text-slate-400">Feature</th>
              <th class="text-center py-3 px-4 font-medium text-slate-500">Google Analytics</th>
              <th class="text-center py-3 px-4 font-medium text-slate-500">Plausible</th>
              <th class="text-center py-3 px-4 font-medium text-slate-500">Umami</th>
              <th class="text-center py-3 px-4 font-medium text-flare-400">Flare CMS</th>
            </tr>
          </thead>
          <tbody>
            {analyticsComparison.map((row) => (
              <tr class="border-b border-slate-800/50">
                <td class="py-3 px-4 text-slate-300">{row.feature}</td>
                <td class="text-center py-3 px-4">
                  <span class:list={[row.ga === '✗' ? 'text-slate-600' : row.ga === '✓' ? 'text-emerald-400' : 'text-slate-500']}>
                    {row.ga}
                  </span>
                </td>
                <td class="text-center py-3 px-4">
                  <span class:list={[row.plausible === '✗' ? 'text-slate-600' : row.plausible === '✓' ? 'text-emerald-400' : 'text-slate-500']}>
                    {row.plausible}
                  </span>
                </td>
                <td class="text-center py-3 px-4">
                  <span class:list={[row.umami === '✗' ? 'text-slate-600' : row.umami === '✓' ? 'text-emerald-400' : 'text-slate-500']}>
                    {row.umami}
                  </span>
                </td>
                <td class:list={['text-center py-3 px-4', row.flareHighlight ? 'bg-flare-500/5' : '']}>
                  <span class:list={[row.flare === '✗' ? 'text-slate-600' : row.flare === '✓' ? 'text-emerald-400' : 'text-cyan-400 font-medium']}>
                    {row.flare}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs text-slate-600">
        * Google Analytics is free but monetizes your visitors' data. Plausible starts at $9/mo. Umami has a free hobby tier (10K events) then $9/mo+.
      </p>
    </section>

    <!-- === Plugin List === -->
    <section class="mb-24">
      <div class="text-center mb-12">
        <span class="text-xs text-purple-400 uppercase tracking-widest font-medium">Plugin Ecosystem</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-sans font-bold tracking-tight">
          15 plugins, day one
        </h2>
        <p class="mt-3 text-slate-400 max-w-xl mx-auto">
          Every plugin ships with the core. Install, activate, configure — no marketplace hunting.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { name: 'Authentication', desc: 'JWT auth, session management, RBAC', icon: '🔐' },
          { name: 'Media Manager', desc: 'R2 storage, thumbnails, folders', icon: '🖼️' },
          { name: 'Cache System', desc: 'Three-tier KV caching with invalidation', icon: '⚡' },
          { name: 'Analytics', desc: 'Usage tracking and performance dashboards', icon: '📊' },
          { name: 'AI Search', desc: 'Semantic search with Vectorize + RAG', icon: '🔍' },
          { name: 'Workflow Engine', desc: 'Multi-stage approval pipelines', icon: '🔄' },
          { name: 'Email Templates', desc: 'Themed emails with Resend delivery', icon: '📧' },
          { name: 'Quill Editor', desc: 'Rich text with custom toolbar and light mode', icon: '✏️' },
          { name: 'Turnstile', desc: 'Cloudflare CAPTCHA with headless mode', icon: '🛡️' },
          { name: 'OTP Login', desc: 'Passwordless one-time-password auth', icon: '🔑' },
          { name: 'Database Tools', desc: 'Migrations, schema inspection, admin tools', icon: '🗄️' },
          { name: 'Seed Data', desc: 'Demo content generation for development', icon: '🌱' },
          { name: 'Testimonials', desc: 'Reviews and ratings management', icon: '💬' },
          { name: 'Code Examples', desc: 'Syntax-highlighted code snippets', icon: '📝' },
          { name: 'Demo Login', desc: 'Quick access for testing environments', icon: '🎭' },
        ].map((plugin) => (
          <div class="flex items-start gap-3 p-4 rounded-lg border border-slate-800/50 bg-slate-800/20 hover:bg-slate-800/40 transition-colors">
            <span class="text-lg mt-0.5">{plugin.icon}</span>
            <div>
              <div class="text-sm font-medium text-slate-200">{plugin.name}</div>
              <div class="text-xs text-slate-500 mt-0.5">{plugin.desc}</div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-8 text-center">
        <p class="text-sm text-slate-500">
          Build your own with the <span class="text-slate-300">Plugin SDK</span> — TypeScript builder API, lifecycle hooks, custom routes, and admin page registration.
        </p>
      </div>
    </section>

    <!-- === Roadmap === -->
    <section class="mb-24">
      <div class="text-center mb-12">
        <span class="text-xs text-flare-400 uppercase tracking-widest font-medium">Roadmap</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-sans font-bold tracking-tight">
          What's next
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-5 max-w-3xl mx-auto">
        {roadmap.map((item) => (
          <div class="p-6 rounded-xl border border-slate-800 bg-slate-800/30">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-sans font-semibold text-slate-50">{item.title}</h3>
              <span class="text-[10px] font-mono text-slate-600 bg-slate-800 px-2 py-0.5 rounded">{item.quarter}</span>
            </div>
            <p class="text-sm text-slate-400 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- === Bottom CTA === -->
    <section>
      <div class="rounded-2xl border border-flare-500/20 bg-gradient-to-br from-flare-500/5 to-transparent p-8 sm:p-12 text-center">
        <h2 class="text-2xl sm:text-3xl font-sans font-bold tracking-tight mb-4">
          Ready to build on the edge?
        </h2>
        <p class="text-slate-400 mb-8 max-w-lg mx-auto">
          Get started in under 5 minutes. One command, and you're running a headless CMS on Cloudflare Workers.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
            href="/docs/getting-started/quickstart"
            class="inline-flex items-center gap-2 px-6 py-3 bg-flare-500 hover:bg-flare-400 text-slate-950 text-sm font-semibold rounded-lg transition-colors"
            onclick="plausible('CTA: Quick Start', {props: {location: 'features'}})"
          >
            Quick Start
          </a>
          <a
            href="https://admin.flarecms.dev"
            class="inline-flex items-center gap-2 px-6 py-3 border border-slate-700 hover:border-slate-500 text-slate-300 hover:text-slate-50 text-sm font-medium rounded-lg transition-all"
            onclick="plausible('CTA: Try Demo')"
          >
            Try the Admin Demo
          </a>
        </div>
        <div class="mt-6">
          <code class="text-xs text-slate-500 font-mono bg-slate-800/60 px-3 py-1.5 rounded border border-slate-700/50">
            git clone https://github.com/jjaimealeman/flarecms my-site
          </code>
        </div>
      </div>
    </section>

  </div>
</Layout>
