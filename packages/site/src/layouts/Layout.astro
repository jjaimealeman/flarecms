---
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import SearchModal from "../components/SearchModal.astro";
import FlareAnalytics from "../components/FlareAnalytics.astro";
import { navLinks } from "../data/homepage";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Edge-native headless CMS for Cloudflare Workers. Built on D1, R2, and Hono.",
} = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="min-h-screen">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={title} description={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Plausible Analytics -->
    <script defer data-domain="flarecms.dev" src="https://stats.915websites.com/js/script.hash.outbound-links.pageview-props.tagged-events.js"></script>
    <script is:inline>window.plausible = window.plausible || function() { (window.plausible.q = window.plausible.q || []).push(arguments) }</script>
    <!-- Theme: prevent FOUC -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('flare-theme');
        if (t === 'light' || (!t && window.matchMedia('(prefers-color-scheme: light)').matches)) {
          document.documentElement.classList.add('light');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-surface-primary text-text-primary font-sans antialiased">
    <!-- Navigation -->
    <nav
      id="site-nav"
      class="sticky top-0 z-50 bg-surface-primary/80 backdrop-blur-xl border-b border-border transition-all duration-300"
    >
      <div
        class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between transition-all duration-300"
        id="site-nav-inner"
      >
        <!-- Logo + Desktop nav -->
        <div class="hidden md:flex items-center gap-6">
          <a
            href="/"
            class="flex items-center gap-2 shrink-0 transition-all duration-300"
            id="site-logo-link"
          >
            <img
              src="/logo.svg"
              alt="Flare CMS"
              class="h-7 w-auto transition-all duration-300 logo-dark"
              id="site-logo"
            />
            <img
              src="/logo-light.svg"
              alt="Flare CMS"
              class="h-7 w-auto transition-all duration-300 logo-light hidden"
            />
          </a>
          <div class="w-px h-5 bg-border"></div>
          {
            navLinks
              .filter((link) => link.href !== "/")
              .map((link) => (
                <a
                  href={link.href}
                  class:list={[
                    "text-sm font-medium transition-colors",
                    (
                      link.href === "/"
                        ? currentPath === "/"
                        : currentPath.startsWith(link.href)
                    )
                      ? "text-flare-500"
                      : "text-text-secondary hover:text-text-primary",
                  ]}
                >
                  {link.label}
                </a>
              ))
          }
        </div>

        <!-- Search + Theme toggle + CTA (desktop) -->
        <div class="hidden md:flex items-center gap-3">
          <button
            id="search-trigger"
            class="hidden lg:flex items-center gap-2 px-3 py-1.5 rounded-lg border border-border text-xs text-text-tertiary hover:border-text-tertiary transition-colors cursor-pointer"
            aria-label="Search docs"
          >
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
            <span>Search docs...</span>
            <kbd
              class="ml-2 px-1.5 py-0.5 rounded bg-surface-tertiary text-[10px] font-mono text-text-tertiary border border-border"
              >Cmd+K</kbd
            >
          </button>
          <!-- GitHub star badge -->
          <a
            href="https://github.com/jjaimealeman/flarecms"
            target="_blank"
            rel="noopener"
            class="text-text-secondary hover:text-text-primary transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
          </a>
          <!-- Theme toggle -->
          <button
            id="theme-toggle"
            class="p-2 rounded-lg text-text-secondary hover:text-text-primary hover:bg-surface-tertiary transition-colors cursor-pointer"
            aria-label="Toggle theme"
          >
            <!-- Sun icon (shown in dark mode) -->
            <svg class="w-4 h-4 theme-icon-sun" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="5"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72 1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
            </svg>
            <!-- Moon icon (shown in light mode) -->
            <svg class="w-4 h-4 theme-icon-moon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
          <!-- TODO: Re-enable when /demo with roles + OTP login is ready -->
        </div>

        <!-- Mobile logo + hamburger -->
        <a href="/" class="md:hidden flex items-center">
          <img src="/logo.svg" alt="Flare CMS" class="h-6 w-auto logo-dark" />
          <img src="/logo-light.svg" alt="Flare CMS" class="h-6 w-auto logo-light hidden" />
        </a>
        <div class="md:hidden flex items-center gap-2">
          <!-- Mobile theme toggle -->
          <button
            class="theme-toggle-mobile p-2 rounded-lg text-text-secondary hover:text-text-primary transition-colors cursor-pointer"
            aria-label="Toggle theme"
          >
            <svg class="w-5 h-5 theme-icon-sun" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="5"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72 1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
            </svg>
            <svg class="w-5 h-5 theme-icon-moon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
          <button
            id="site-mobile-menu-btn"
            class="text-text-secondary hover:text-text-primary transition-colors"
            aria-label="Open menu"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- Mobile nav overlay -->
    <div id="site-mobile-overlay" class="fixed inset-0 z-[55] hidden">
      <!-- Backdrop -->
      <div
        id="site-mobile-backdrop"
        class="absolute inset-0 bg-surface-primary/80 backdrop-blur-sm"
      >
      </div>

      <!-- Slide-in panel from right -->
      <div
        class="absolute right-0 top-0 bottom-0 w-72 bg-surface-secondary border-l border-border overflow-y-auto transform transition-transform"
      >
        <!-- Close button -->
        <div
          class="flex items-center justify-between p-4 border-b border-border"
        >
          <span class="text-sm font-semibold text-text-secondary">Menu</span>
          <button
            id="site-mobile-close-btn"
            class="text-text-secondary hover:text-text-primary transition-colors"
            aria-label="Close menu"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <!-- Search trigger (mobile) -->
        <div class="px-4 pt-4 pb-2">
          <button
            class="search-trigger-mobile flex items-center gap-2 w-full px-3 py-2.5 rounded-lg border border-border text-sm text-text-secondary hover:border-text-tertiary hover:text-text-primary transition-colors cursor-pointer"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
            Search docs...
          </button>
        </div>

        <!-- Nav links -->
        <div class="p-4 space-y-1">
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                class:list={[
                  "block px-3 py-2.5 rounded-lg text-sm font-medium transition-colors",
                  (
                    link.href === "/"
                      ? currentPath === "/"
                      : currentPath.startsWith(link.href)
                  )
                    ? "text-flare-500 bg-flare-500/10"
                    : "text-text-secondary hover:text-text-primary hover:bg-surface-tertiary",
                ]}
              >
                {link.label}
              </a>
            ))
          }
          <a
            href="https://github.com/jjaimealeman/flarecms"
            target="_blank"
            rel="noopener"
            class="flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-surface-tertiary transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            GitHub
          </a>
        </div>

        <!-- TODO: Re-enable when /demo with roles + OTP login is ready -->
      </div>
    </div>

    <main id="site-main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-border mt-20 bg-surface-primary">
      <div class="max-w-7xl mx-auto px-6 py-16">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
          <!-- Brand column -->
          <div class="col-span-2 md:col-span-1">
            <a
              href="/"
              class="inline-block hover:opacity-80 transition-opacity"
            >
              <img src="/favicon.svg" alt="Flare CMS" class="h-8 w-auto logo-dark" />
              <img src="/favicon-light.svg" alt="Flare CMS" class="h-8 w-auto logo-light hidden" />
            </a>
            <p class="mt-3 text-sm text-text-secondary leading-relaxed">
              Edge-native headless CMS for Cloudflare Workers.
            </p>
            <div
              class="mt-4 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-surface-tertiary border border-border text-xs text-text-secondary"
            >
              <span class="w-1.5 h-1.5 rounded-full bg-flare-500"></span>
              Built with Flare CMS
            </div>
          </div>

          <!-- Product -->
          <div>
            <h4
              class="text-xs font-semibold text-text-secondary uppercase tracking-wider mb-4"
            >
              Product
            </h4>
            <ul class="space-y-3">
              <li>
                <a
                  href="/docs"
                  class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                  >Documentation</a>
              </li>
              <li>
                <a
                  href="/features"
                  class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                  >Features</a>
              </li>
              <li>
                <a
                  href="/comparison"
                  class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                  >Comparison</a>
              </li>
              <li>
                <a
                  href="/blog"
                  class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                  >Blog</a>
              </li>
              <li>
                <a
                  href="/faq"
                  class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                  >FAQ</a>
              </li>
              <!-- TODO: Re-enable when /demo with roles + OTP login is ready -->
            </ul>
          </div>

          <!-- Developers -->
          <div>
            <h4
              class="text-xs font-semibold text-text-secondary uppercase tracking-wider mb-4"
            >
              Developers
            </h4>
            <ul class="space-y-3">
              <li>
                <a
                  href="/docs"
                  class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                  >Quick Start</a>
              </li>
              <li>
                <a
                  href="https://github.com/jjaimealeman/flarecms"
                  target="_blank"
                  rel="noopener"
                  class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                  >GitHub</a>
              </li>
              <li>
                <a
                  href="https://github.com/jjaimealeman/flarecms/issues"
                  target="_blank"
                  rel="noopener"
                  class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                  >Issues</a>
              </li>
            </ul>
          </div>

          <!-- Legal -->
          <div>
            <h4
              class="text-xs font-semibold text-text-secondary uppercase tracking-wider mb-4"
            >
              Legal
            </h4>
            <ul class="space-y-3">
              <li>
                <a
                  href="/terms"
                  class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                  >Terms of Service</a>
              </li>
              <li>
                <a
                  href="/privacy"
                  class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                  >Privacy Policy</a>
              </li>
              <li>
                <a
                  href="/code-of-conduct"
                  class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                  >Code of Conduct</a>
              </li>
              <li>
                <a
                  href="https://github.com/jjaimealeman/flarecms/blob/main/LICENSE"
                  target="_blank"
                  rel="noopener"
                  class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                  >MIT License</a>
              </li>
            </ul>
          </div>
        </div>

        <!-- Bottom bar -->
        <div
          class="mt-12 pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-text-tertiary"
        >
          <span>&copy; 2026 Flare CMS &middot; MIT License</span>
          <div class="flex items-center gap-4">
            <span>Built by Jaime Aleman in El Paso, TX</span>
            <span
              id="version-badge"
              class="font-mono text-text-tertiary cursor-pointer hover:text-text-secondary transition-colors"
              title="Click to copy"
            >
              v{__APP_VERSION__} &middot; {__GIT_HASH__}
            </span>
          </div>
        </div>
      </div>
    </footer>

    <!-- Scroll-shrink header -->
    <script is:inline>
      (function () {
        var inner = document.getElementById("site-nav-inner");
        var logo = document.getElementById("site-logo");
        var scrolled = false;

        function onScroll() {
          var isScrolled = window.scrollY > 20;
          if (isScrolled === scrolled) return;
          scrolled = isScrolled;
          if (inner) {
            inner.style.paddingTop = isScrolled ? "0.5rem" : "";
            inner.style.paddingBottom = isScrolled ? "0.5rem" : "";
          }
          if (logo) {
            logo.style.height = isScrolled ? "1.25rem" : "";
          }
        }

        window.addEventListener("scroll", onScroll, { passive: true });
      })();
    </script>

    <!-- Mobile menu script -->
    <script is:inline>
      (function () {
        var btn = document.getElementById("site-mobile-menu-btn");
        var overlay = document.getElementById("site-mobile-overlay");
        var backdrop = document.getElementById("site-mobile-backdrop");
        var closeBtn = document.getElementById("site-mobile-close-btn");

        function open() {
          overlay && overlay.classList.remove("hidden");
        }
        function close() {
          overlay && overlay.classList.add("hidden");
        }

        btn && btn.addEventListener("click", open);
        backdrop && backdrop.addEventListener("click", close);
        closeBtn && closeBtn.addEventListener("click", close);

        // Close when any nav link is clicked
        if (overlay) {
          overlay.addEventListener("click", function (e) {
            if (e.target && e.target.closest && e.target.closest("a")) {
              close();
            }
          });
        }
      })();
    </script>

    <!-- Theme toggle script -->
    <script is:inline>
      (function () {
        function isLight() {
          return document.documentElement.classList.contains('light');
        }

        function updateIcons() {
          var light = isLight();
          document.querySelectorAll('.theme-icon-sun').forEach(function(el) {
            el.style.display = light ? 'none' : '';
            el.classList.toggle('hidden', light);
          });
          document.querySelectorAll('.theme-icon-moon').forEach(function(el) {
            el.style.display = light ? '' : 'none';
            el.classList.toggle('hidden', !light);
          });
        }

        function toggle() {
          var light = isLight();
          if (light) {
            document.documentElement.classList.remove('light');
            localStorage.setItem('flare-theme', 'dark');
          } else {
            document.documentElement.classList.add('light');
            localStorage.setItem('flare-theme', 'light');
          }
          updateIcons();
        }

        // Bind all toggle buttons
        var btn = document.getElementById('theme-toggle');
        if (btn) btn.addEventListener('click', toggle);
        document.querySelectorAll('.theme-toggle-mobile').forEach(function(el) {
          el.addEventListener('click', toggle);
        });

        updateIcons();
      })();
    </script>

    <!-- Version badge click-to-copy -->
    <script
      is:inline
      define:vars={{ version: `v${__APP_VERSION__} · ${__GIT_HASH__}` }}
    >
      document
        .getElementById("version-badge")
        ?.addEventListener("click", function () {
          navigator.clipboard.writeText(version).then(() => {
            const el = this;
            const orig = el.textContent;
            el.textContent = "Copied!";
            setTimeout(() => {
              el.textContent = orig;
            }, 1500);
          });
        });
    </script>

    <SearchModal />
    <FlareAnalytics />
  </body>
</html>
