---
import { getNewsArticleBySlug } from '../../lib/flare'
import Layout from '../../layouts/Layout.astro'

const { slug } = Astro.params

let article: any = null
try {
  article = await getNewsArticleBySlug(slug!)
} catch {
  // CMS API unavailable
}

if (!article) {
  return new Response(null, { status: 404, statusText: 'Not Found' })
}

const categoryStyles: Record<string, string> = {
  technology: 'bg-cyan-500/10 text-cyan-400',
  business: 'bg-amber-500/10 text-amber-400',
  general: 'bg-slate-700 text-slate-300',
}
---

<Layout title={article.data.title}>
  <article class="max-w-3xl mx-auto px-6 pt-12 pb-20">
    <header class="mb-10">
      <a href="/news" class="inline-flex items-center text-sm text-slate-500 hover:text-flare-400 transition-colors mb-6">
        &larr; Back to News
      </a>
      <div class="flex items-center gap-3 mb-4">
        {article.data.category && (
          <span class:list={[
            'inline-block px-2.5 py-0.5 rounded-md text-xs font-medium',
            categoryStyles[article.data.category] || 'bg-slate-700 text-slate-300'
          ]}>
            {article.data.category}
          </span>
        )}
      </div>
      <h1 class="text-4xl font-heading font-bold tracking-tight leading-tight">
        {article.data.title}
      </h1>
      <div class="mt-4 flex items-center gap-4 text-sm text-slate-500">
        {article.data.author && (
          <span>By {article.data.author}</span>
        )}
        {article.data.publish_date && (
          <time datetime={article.data.publish_date}>
            {new Date(article.data.publish_date).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </time>
        )}
      </div>
    </header>

    <div class="prose prose-lg prose-invert max-w-none prose-headings:font-heading prose-headings:tracking-tight prose-a:text-flare-400 prose-pre:bg-slate-950 prose-pre:rounded-xl" set:html={article.data.content} />

    <footer class="mt-16 pt-8 border-t border-slate-800">
      <a href="/news" class="inline-flex items-center text-sm font-medium text-flare-500 hover:text-flare-400 transition-colors">
        &larr; Back to News
      </a>
    </footer>
  </article>
</Layout>
