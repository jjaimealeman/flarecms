---
import { comparisonRows } from '../data/homepage'
---

<section class="py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">
        Why Flare CMS?
      </h2>
      <p class="mt-4 text-text-secondary max-w-2xl mx-auto">
        Most headless CMS platforms require external databases, separate hosting, and complex infrastructure.
        Flare CMS runs entirely on Cloudflare — database, storage, and compute in one stack.
      </p>
      <a href="/comparison" class="inline-flex items-center gap-1 mt-3 text-sm text-flare-400 hover:text-flare-300 transition-colors">
        See full comparison with 7 CMS platforms
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Desktop table (hidden on mobile) -->
    <div class="hidden md:block">
      <table class="w-full border-collapse">
        <thead class="sticky top-16 z-10 bg-surface-primary">
          <tr class="border-b border-border">
            <th class="text-left py-4 px-6 text-sm font-medium text-text-secondary">Feature</th>
            <th class="text-left py-4 px-6 text-sm font-medium text-text-secondary">Traditional CMS</th>
            <th class="text-left py-4 px-6 text-sm font-medium text-flare-500 border-l-2 border-flare-500/30">Flare CMS</th>
          </tr>
        </thead>
        <tbody>
          {comparisonRows.map((row) => (
            <tr class="border-b border-border/50">
              <td class="py-4 px-6 text-sm font-medium text-text-primary">{row.feature}</td>
              <td class="py-4 px-6 text-sm text-text-tertiary">{row.traditional}</td>
              <td class:list={[
                'py-4 px-6 text-sm font-medium border-l-2 border-flare-500/30 bg-flare-500/5',
                row.flareHighlight ? 'text-cyan-400' : 'text-text-secondary'
              ]}>
                {row.flare}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Mobile card layout (hidden on desktop) -->
    <div class="md:hidden space-y-4">
      {comparisonRows.map((row) => (
        <div class="rounded-xl border border-border bg-surface-secondary p-4">
          <div class="text-sm font-medium text-text-primary mb-3">{row.feature}</div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <div class="text-xs text-text-tertiary uppercase tracking-wide mb-1">Traditional</div>
              <div class="text-sm text-text-tertiary">{row.traditional}</div>
            </div>
            <div>
              <div class="text-xs text-flare-500 uppercase tracking-wide mb-1">Flare CMS</div>
              <div class:list={[
                'text-sm font-medium',
                row.flareHighlight ? 'text-cyan-400' : 'text-text-secondary'
              ]}>
                {row.flare}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
