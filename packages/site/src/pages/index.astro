---
import Layout from '../layouts/Layout.astro';
import { getBlogPosts, getNewsArticles } from '../lib/flare';

let posts: any[] = [];
let news: any[] = [];
let debugError = '';

try {
  posts = await getBlogPosts();
  news = await getNewsArticles();
} catch (e: any) {
  debugError = `API_URL: ${import.meta.env.FLARE_API_URL || 'NOT SET'} | Error: ${e.message}`;
  console.error('Flare API error:', debugError);
}

const recentPosts = posts.slice(0, 3);
const latestNews = news.slice(0, 3);
---

<Layout title="Home">
  {debugError && <div class="bg-red-100 text-red-800 p-4 m-4 rounded font-mono text-sm">{debugError}</div>}
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-16">
    <div class="max-w-2xl">
      <h1 class="text-5xl font-bold tracking-tight text-gray-900 leading-tight">
        Content at the
        <span class="text-indigo-600">edge</span>.
      </h1>
      <p class="mt-6 text-lg text-gray-600 leading-relaxed">
        A headless CMS powered by Flare CMS and Cloudflare Workers,
        with an Astro frontend delivering content at sub-50ms globally.
      </p>
      <div class="mt-8 flex gap-4">
        <a
          href="/blog"
          class="inline-flex items-center px-5 py-2.5 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors"
        >
          Read the blog
        </a>
        <a
          href="https://sonicjs.com"
          class="inline-flex items-center px-5 py-2.5 bg-white text-gray-700 text-sm font-medium rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors"
        >
          Flare CMS docs
        </a>
      </div>
    </div>
  </section>

  {recentPosts.length > 0 && (
    <section class="max-w-5xl mx-auto px-6 pb-20">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-gray-900">Recent posts</h2>
        <a href="/blog" class="text-sm font-medium text-indigo-600 hover:text-indigo-700 transition-colors">
          View all &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentPosts.map((post) => (
          <a href={`/blog/${post.data.slug}`} class="group block">
            <article class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg hover:border-gray-300 transition-all duration-200">
              {post.data.featuredImage && (
                <img
                  src={post.data.featuredImage}
                  alt={post.data.title}
                  loading="lazy"
                  class="w-full h-48 object-cover"
                />
              )}
              <div class="p-5">
                <h3 class="font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors">
                  {post.data.title}
                </h3>
                {post.data.excerpt && (
                  <p class="mt-2 text-sm text-gray-600 line-clamp-2">{post.data.excerpt}</p>
                )}
                {post.data.publishedAt && (
                  <time datetime={post.data.publishedAt} class="mt-3 block text-xs text-gray-400">
                    {new Date(post.data.publishedAt).toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric'
                    })}
                  </time>
                )}
              </div>
            </article>
          </a>
        ))}
      </div>
    </section>
  )}

  {latestNews.length > 0 && (
    <section class="max-w-5xl mx-auto px-6 pb-20">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-gray-900">Latest news</h2>
        <a href="/news" class="text-sm font-medium text-indigo-600 hover:text-indigo-700 transition-colors">
          View all &rarr;
        </a>
      </div>

      <div class="space-y-3">
        {latestNews.map((article) => (
          <a href={`/news/${article.slug}`} class="group block">
            <article class="bg-white rounded-xl border border-gray-200 hover:shadow-lg hover:border-gray-300 transition-all duration-200 p-5 flex items-center justify-between gap-4">
              <div class="flex items-center gap-4 min-w-0">
                {article.data.category && (
                  <span class:list={[
                    "shrink-0 inline-block px-2.5 py-0.5 rounded-full text-xs font-medium",
                    article.data.category === 'technology' && "bg-blue-100 text-blue-700",
                    article.data.category === 'business' && "bg-amber-100 text-amber-700",
                    article.data.category === 'general' && "bg-gray-100 text-gray-700",
                  ]}>
                    {article.data.category}
                  </span>
                )}
                <h3 class="font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors truncate">
                  {article.data.title}
                </h3>
              </div>
              <div class="flex items-center gap-3 shrink-0">
                {article.data.publish_date && (
                  <time datetime={article.data.publish_date} class="text-xs text-gray-400 hidden sm:block">
                    {new Date(article.data.publish_date).toLocaleDateString('en-US', {
                      month: 'short',
                      day: 'numeric'
                    })}
                  </time>
                )}
                <span class="text-gray-400 group-hover:text-indigo-600 transition-colors">&rarr;</span>
              </div>
            </article>
          </a>
        ))}
      </div>
    </section>
  )}
</Layout>
