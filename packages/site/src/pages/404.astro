---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Not Found">
  <div class="max-w-3xl mx-auto px-6 pt-24 pb-20 text-center">
    <div class="text-8xl font-heading font-bold text-slate-800">404</div>
    <h1 class="mt-4 text-2xl font-heading font-semibold">Page not found</h1>
    <p class="mt-3 text-slate-400">The page you're looking for doesn't exist or has been moved.</p>
    <a
      href="/"
      class="inline-flex items-center gap-2 mt-8 px-6 py-3 bg-flare-500 hover:bg-flare-400 text-slate-950 text-sm font-semibold rounded-lg transition-colors"
    >
      &larr; Back to home
    </a>
  </div>
</Layout>
