---
import { getCollection } from 'astro:content'
import Layout from '../layouts/Layout.astro'

const { slug } = Astro.params

const allPages = await getCollection('pages')
const entry = allPages.find(p => p.data.slug === slug)

if (!entry) {
  return new Response(null, { status: 404, statusText: 'Not Found' })
}

const page = { data: entry.data }
---

<Layout title={page.data.title} description={page.data.meta_description}>
  <article class="max-w-3xl mx-auto px-6 pt-12 pb-20">
    <header class="mb-10">
      <h1 class="text-4xl font-heading font-bold tracking-tight leading-tight">
        {page.data.title}
      </h1>
    </header>

    <div class="prose prose-lg prose-invert max-w-none prose-headings:font-heading prose-headings:tracking-tight prose-a:text-flare-400 prose-pre:bg-slate-950 prose-pre:rounded-xl" set:html={page.data.content} />
  </article>
</Layout>
