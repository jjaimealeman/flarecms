---
import { stats } from '../data/homepage'
---

<section class="border-y border-slate-800 bg-slate-950/50">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-4 gap-8">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-4xl font-heading font-bold text-slate-50">
            {stat.value}
          </div>
          <div class="mt-2 text-sm text-slate-500 uppercase tracking-wider">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
