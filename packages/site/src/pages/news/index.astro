---
import { getNewsArticles } from '../../lib/flare'
import { getAllStaticNewsArticles } from '../../data/news-articles'
import Layout from '../../layouts/Layout.astro'

const categoryStyles: Record<string, string> = {
  technology: 'bg-cyan-500/10 text-cyan-400',
  business: 'bg-amber-500/10 text-amber-400',
  general: 'bg-slate-700/50 text-slate-300',
}

// Try CMS first, fall back to static
let cmsArticles: any[] = []
try {
  cmsArticles = await getNewsArticles()
} catch {
  // CMS unavailable
}

const staticArticles = getAllStaticNewsArticles()
const hasCmsData = cmsArticles.length > 0

const articles = hasCmsData
  ? cmsArticles.map(a => ({
      slug: a.slug,
      title: a.data.title,
      category: a.data.category || 'general',
      author: a.data.author || '',
      date: a.data.publish_date || new Date(a.created_at).toISOString(),
    }))
  : staticArticles.map(a => ({
      slug: a.slug,
      title: a.title,
      category: a.category,
      author: a.author,
      date: a.date,
    }))
---

<Layout title="News">
  <div class="max-w-5xl mx-auto px-6 pt-12 pb-20">
    <header class="mb-12">
      <h1 class="text-4xl font-heading font-bold tracking-tight">News</h1>
      <p class="mt-2 text-slate-400">Technology, business, and community updates.</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {articles.map((article) => (
        <a href={`/news/${article.slug}`} class="group block">
          <article class="h-full rounded-xl border border-slate-800 bg-slate-800/30 hover:bg-slate-800/60 hover:border-slate-700 transition-all p-6 flex flex-col">
            <span class:list={[
              'self-start inline-block px-2.5 py-1 rounded-md text-xs font-medium mb-3',
              categoryStyles[article.category] || 'bg-slate-700 text-slate-300'
            ]}>
              {article.category}
            </span>
            <h2 class="font-heading font-semibold text-slate-50 group-hover:text-flare-400 transition-colors mb-3">
              {article.title}
            </h2>
            <div class="mt-auto pt-4 flex items-center justify-between text-xs text-slate-500">
              {article.author && <span>{article.author}</span>}
              <time datetime={article.date}>
                {new Date(article.date).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric'
                })}
              </time>
            </div>
          </article>
        </a>
      ))}
    </div>

    {articles.length === 0 && (
      <div class="text-center py-20">
        <p class="text-slate-500">No news articles yet.</p>
      </div>
    )}
  </div>
</Layout>
