---
import Layout from '../../layouts/Layout.astro'
import { competitors, flareScores, scoreLabels } from '../../data/comparison'

const { slug } = Astro.params
const cms = competitors.find((c) => c.slug === slug)

if (!cms) {
  return Astro.redirect('/comparison')
}

const scoreKeys = Object.keys(scoreLabels) as (keyof typeof flareScores)[]

// Color variants
const colorClasses: Record<string, { text: string; bg: string; border: string; bar: string }> = {
  blue: { text: 'text-blue-400', bg: 'bg-blue-500/10', border: 'border-blue-500/30', bar: 'bg-blue-500' },
  orange: { text: 'text-orange-400', bg: 'bg-orange-500/10', border: 'border-orange-500/30', bar: 'bg-orange-500' },
  purple: { text: 'text-purple-400', bg: 'bg-purple-500/10', border: 'border-purple-500/30', bar: 'bg-purple-500' },
  indigo: { text: 'text-indigo-400', bg: 'bg-indigo-500/10', border: 'border-indigo-500/30', bar: 'bg-indigo-500' },
  teal: { text: 'text-teal-400', bg: 'bg-teal-500/10', border: 'border-teal-500/30', bar: 'bg-teal-500' },
  emerald: { text: 'text-emerald-400', bg: 'bg-emerald-500/10', border: 'border-emerald-500/30', bar: 'bg-emerald-500' },
  red: { text: 'text-red-400', bg: 'bg-red-500/10', border: 'border-red-500/30', bar: 'bg-red-500' },
}

const colors = colorClasses[cms.color] || colorClasses.blue
const detailKeys = Object.keys(cms.details) as (keyof typeof cms.details)[]

const detailLabels: Record<string, string> = {
  hosting: 'Hosting',
  database: 'Database',
  media: 'Media Storage',
  api: 'API',
  adminUI: 'Admin UI',
  auth: 'Authentication',
  caching: 'Caching',
  deployment: 'Deployment',
}

const flareDetails: Record<string, string> = {
  hosting: 'Cloudflare Workers. Zero cold starts, 330+ edge locations.',
  database: 'D1 (SQLite at the edge). Built-in, no setup.',
  media: 'R2 object storage. Built-in media library with upload pipeline.',
  api: 'REST API. Auto-generated from collection schemas.',
  adminUI: 'Built-in admin dashboard. Rich text, media library, users.',
  auth: 'Built-in JWT auth. Admin users and API keys.',
  caching: 'KV edge cache. Sub-millisecond reads globally.',
  deployment: 'wrangler deploy. One command to production.',
}

// Find adjacent competitors for prev/next nav
const idx = competitors.findIndex((c) => c.slug === cms.slug)
const prev = idx > 0 ? competitors[idx - 1] : null
const next = idx < competitors.length - 1 ? competitors[idx + 1] : null
---

<Layout title={`Flare CMS vs ${cms.name}`} description={`Compare Flare CMS with ${cms.name}. ${cms.summary.slice(0, 120)}`}>
  <div class="max-w-4xl mx-auto px-6 pt-12 pb-24">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-8">
      <a href="/comparison" class="hover:text-slate-300 transition-colors">Comparison</a>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
      <span class="text-slate-400">{cms.name}</span>
    </nav>

    <!-- Header -->
    <header class="mb-12">
      <div class="flex items-center gap-4 mb-4">
        <span class="text-4xl">{cms.logo}</span>
        <div>
          <h1 class="text-3xl sm:text-4xl font-sans font-bold tracking-tight">
            Flare CMS vs {cms.name}
          </h1>
          <p class="mt-1 text-sm text-slate-500">{cms.tagline} · <a href={cms.website} target="_blank" rel="noopener" class:list={['hover:underline', colors.text]}>{cms.website.replace('https://', '')}</a></p>
        </div>
      </div>
      <div class="flex flex-wrap gap-2 mt-4">
        <span class:list={['text-xs px-2 py-1 rounded-full border', colors.border, colors.bg, colors.text]}>
          {cms.category === 'headless' ? 'Headless CMS' : cms.category === 'git-based' ? 'Git-based CMS' : 'Traditional CMS'}
        </span>
        {cms.openSource && (
          <span class="text-xs px-2 py-1 rounded-full border border-emerald-500/30 bg-emerald-500/10 text-emerald-400">Open Source</span>
        )}
        {!cms.openSource && (
          <span class="text-xs px-2 py-1 rounded-full border border-slate-600 bg-slate-800 text-slate-400">Proprietary</span>
        )}
        {cms.selfHosted && (
          <span class="text-xs px-2 py-1 rounded-full border border-cyan-500/30 bg-cyan-500/10 text-cyan-400">Self-Hosted</span>
        )}
        {!cms.selfHosted && (
          <span class="text-xs px-2 py-1 rounded-full border border-slate-600 bg-slate-800 text-slate-400">Cloud Only</span>
        )}
      </div>
    </header>

    <!-- Summary -->
    <section class="mb-12">
      <p class="text-slate-300 leading-relaxed">{cms.summary}</p>
    </section>

    <!-- Score Comparison -->
    <section class="mb-12">
      <h2 class="text-xl font-sans font-bold tracking-tight mb-6">Score comparison</h2>
      <div class="space-y-5">
        {scoreKeys.map((key) => {
          const flareScore = flareScores[key]
          const cmsScore = cms.scores[key]
          const flareWins = flareScore > cmsScore
          const tie = flareScore === cmsScore
          return (
            <div>
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm text-slate-300">{scoreLabels[key]}</span>
                <div class="flex items-center gap-3 text-xs font-mono">
                  <span class:list={[flareWins ? 'text-flare-400 font-bold' : 'text-slate-500']}>
                    Flare {flareScore}
                  </span>
                  <span class="text-slate-600">vs</span>
                  <span class:list={[!flareWins && !tie ? colors.text + ' font-bold' : 'text-slate-500']}>
                    {cms.name.split(' ')[0]} {cmsScore}
                  </span>
                </div>
              </div>
              <div class="flex gap-2">
                <div class="flex-1 relative h-2.5 rounded-full bg-slate-800">
                  <div
                    class="absolute inset-y-0 left-0 rounded-full bg-gradient-to-r from-flare-500 to-flare-400"
                    style={`width: ${flareScore * 20}%`}
                  />
                </div>
                <div class="flex-1 relative h-2.5 rounded-full bg-slate-800">
                  <div
                    class:list={['absolute inset-y-0 left-0 rounded-full', colors.bar]}
                    style={`width: ${cmsScore * 20}%; opacity: 0.7`}
                  />
                </div>
              </div>
            </div>
          )
        })}
      </div>
    </section>

    <!-- Strengths & Weaknesses -->
    <section class="mb-12 grid sm:grid-cols-2 gap-6">
      <div class="rounded-xl border border-emerald-500/20 bg-emerald-500/5 p-6">
        <h3 class="text-sm font-semibold text-emerald-400 uppercase tracking-wider mb-4">
          {cms.name} Strengths
        </h3>
        <ul class="space-y-2.5">
          {cms.strengths.map((s) => (
            <li class="flex gap-2 text-sm text-slate-300">
              <span class="text-emerald-400 shrink-0 mt-0.5">+</span>
              {s}
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-xl border border-red-500/20 bg-red-500/5 p-6">
        <h3 class="text-sm font-semibold text-red-400 uppercase tracking-wider mb-4">
          {cms.name} Weaknesses
        </h3>
        <ul class="space-y-2.5">
          {cms.weaknesses.map((w) => (
            <li class="flex gap-2 text-sm text-slate-300">
              <span class="text-red-400 shrink-0 mt-0.5">−</span>
              {w}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Feature-by-Feature -->
    <section class="mb-12">
      <h2 class="text-xl font-sans font-bold tracking-tight mb-6">Feature-by-feature</h2>
      <div class="space-y-4">
        {detailKeys.map((key) => (
          <div class="rounded-xl border border-slate-800 bg-slate-800/30 overflow-hidden">
            <div class="px-5 py-3 border-b border-slate-800">
              <span class="text-sm font-medium text-slate-300">{detailLabels[key]}</span>
            </div>
            <div class="grid sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-slate-800">
              <div class="px-5 py-3">
                <div class="text-[10px] text-flare-400 uppercase tracking-wider font-medium mb-1">Flare CMS</div>
                <p class="text-sm text-slate-300">{flareDetails[key]}</p>
              </div>
              <div class="px-5 py-3">
                <div class:list={['text-[10px] uppercase tracking-wider font-medium mb-1', colors.text]}>{cms.name}</div>
                <p class="text-sm text-slate-400">{cms.details[key]}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Pricing -->
    <section class="mb-12">
      <h2 class="text-xl font-sans font-bold tracking-tight mb-4">Pricing</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="rounded-xl border border-flare-500/20 bg-flare-500/5 p-5">
          <div class="text-sm font-semibold text-flare-400 mb-2">Flare CMS</div>
          <p class="text-sm text-slate-300">Free forever (MIT License). Deploy on Cloudflare's free tier — D1, R2, and Workers included.</p>
        </div>
        <div class="rounded-xl border border-slate-800 bg-slate-800/30 p-5">
          <div class:list={['text-sm font-semibold mb-2', colors.text]}>{cms.name}</div>
          <p class="text-sm text-slate-400">{cms.pricing}</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="mb-12">
      <div class="rounded-2xl border border-flare-500/20 bg-gradient-to-r from-flare-500/10 to-transparent p-8 text-center">
        <h2 class="text-2xl font-sans font-bold tracking-tight mb-3">Ready to try Flare CMS?</h2>
        <p class="text-slate-400 mb-6 max-w-md mx-auto text-sm">
          Get started in minutes. One command to scaffold, one command to deploy.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a
            href="/docs"
            class="inline-flex items-center gap-2 px-6 py-3 bg-flare-500 hover:bg-flare-400 text-slate-950 text-sm font-semibold rounded-lg transition-colors"
          >
            Get Started
          </a>
          <a
            href="/comparison"
            class="inline-flex items-center gap-2 px-6 py-3 border border-slate-700 hover:border-slate-500 text-slate-300 hover:text-slate-50 text-sm font-medium rounded-lg transition-all"
          >
            Back to comparison
          </a>
        </div>
      </div>
    </section>

    <!-- Prev/Next nav -->
    <nav class="flex items-center justify-between pt-8 border-t border-slate-800">
      {prev ? (
        <a href={`/comparison/${prev.slug}`} class="flex items-center gap-2 text-sm text-slate-400 hover:text-slate-200 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          vs {prev.name}
        </a>
      ) : <div />}
      {next ? (
        <a href={`/comparison/${next.slug}`} class="flex items-center gap-2 text-sm text-slate-400 hover:text-slate-200 transition-colors">
          vs {next.name}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ) : <div />}
    </nav>

  </div>
</Layout>
