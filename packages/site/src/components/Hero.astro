---
---

<section class="relative overflow-hidden">
  <!-- Subtle grid pattern background -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(246,130,31,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(246,130,31,0.03)_1px,transparent_1px)] bg-[size:64px_64px]"></div>

  <div class="relative max-w-5xl mx-auto px-6 pt-28 pb-20">
    <!-- Version badge pill -->
    <div class="flex justify-center mb-8">
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-flare-500/15 border border-flare-500/30 text-flare-500 text-xs font-medium">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
        v{__APP_VERSION__} is live
      </div>
    </div>

    <!-- Massive headline -->
    <h1 class="text-5xl sm:text-7xl lg:text-[96px] font-bold tracking-tight leading-[1.05] text-center mb-6">
      The CMS built for<br />
      <span class="bg-[linear-gradient(to_right,var(--color-flare-400)_0%,var(--color-flare-500)_38%,var(--color-cyan-400)_72%)] bg-clip-text text-transparent">the edge</span>
    </h1>

    <!-- Subhead -->
    <p class="text-lg sm:text-xl text-text-secondary text-center max-w-2xl mx-auto mb-10">
      Open-source headless CMS on Cloudflare Workers. Zero cold starts, D1 database, R2 media — globally distributed.
    </p>

    <!-- Two CTA buttons -->
    <div class="flex flex-wrap items-center justify-center gap-4 mb-10">
      <a
        href="/docs/getting-started/quickstart"
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-flare-500 hover:bg-flare-400 text-white text-sm font-semibold rounded-lg transition-colors shadow-lg shadow-flare-500/20"
      >
        Quick Start
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
      <a
        href="https://admin.flarecms.dev"
        class="inline-flex items-center gap-2 px-7 py-3.5 border border-border hover:border-text-tertiary text-text-secondary hover:text-text-primary text-sm font-medium rounded-lg transition-all"
      >
        Admin Demo
      </a>
    </div>

    <!-- CLI snippet -->
    <div class="flex flex-col items-center gap-2 mb-16">
      <div class="inline-flex items-center gap-3 px-5 py-3 rounded-xl bg-surface-secondary border border-border font-mono text-sm text-text-secondary group cursor-pointer" id="cli-snippet" title="Click to copy">
        <span class="text-text-tertiary">$</span>
        <span>git clone https://github.com/jjaimealeman/flarecms my-site</span>
        <button class="text-text-tertiary hover:text-text-secondary transition-colors ml-1" aria-label="Copy command">
          <svg class="w-4 h-4 copy-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
          </svg>
          <svg class="w-4 h-4 check-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12" />
          </svg>
        </button>
      </div>
      <span class="text-[11px] text-text-tertiary">
        <code class="text-text-tertiary">npx create-flare-app</code> coming soon
      </span>
    </div>

    <!-- Admin UI video / screenshot showcase -->
    <div class="relative max-w-5xl mx-auto">
      <div class="rounded-2xl border border-border overflow-hidden shadow-2xl shadow-black/20">
        <!-- Browser chrome -->
        <div class="flex items-center gap-2 px-4 py-3 bg-surface-secondary border-b border-border">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
            <div class="w-3 h-3 rounded-full bg-amber-500/60"></div>
            <div class="w-3 h-3 rounded-full bg-emerald-500/60"></div>
          </div>
          <div class="flex-1 flex justify-center">
            <div class="px-4 py-1 rounded-md bg-surface-tertiary text-xs text-text-tertiary font-mono">
              localhost:8787/admin
            </div>
          </div>
        </div>
        <!-- Admin dashboard screenshot (swaps with theme) -->
        <img
          src="/images/admin-dashboard.webp"
          alt="Flare CMS Admin Dashboard — Dark Mode"
          class="w-full aspect-video object-cover object-top bg-surface-tertiary dark-only"
          loading="eager"
        />
        <img
          src="/images/admin-dashboard-light.webp"
          alt="Flare CMS Admin Dashboard — Light Mode"
          class="w-full aspect-video object-cover object-top bg-surface-tertiary light-only hidden"
          loading="eager"
        />
      </div>
      <!-- Glow effect behind -->
      <div class="absolute -inset-4 -z-10 rounded-3xl bg-gradient-to-b from-flare-500/5 to-transparent blur-2xl"></div>
    </div>

    <!-- Trust badges -->
    <div class="mt-16 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-xs text-text-tertiary">
      <span class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-flare-500"></span>
        Cloudflare Workers
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-cyan-500"></span>
        Astro Frontend
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        MIT License
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
        TypeScript
      </span>
    </div>
  </div>
</section>

<script>
  const snippet = document.getElementById('cli-snippet')
  if (snippet) {
    snippet.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText('git clone https://github.com/jjaimealeman/flarecms my-site')
        const copyIcon = snippet.querySelector('.copy-icon')
        const checkIcon = snippet.querySelector('.check-icon')
        if (copyIcon && checkIcon) {
          copyIcon.classList.add('hidden')
          checkIcon.classList.remove('hidden')
          setTimeout(() => {
            copyIcon.classList.remove('hidden')
            checkIcon.classList.add('hidden')
          }, 2000)
        }
      } catch {
        // Clipboard API not available
      }
    })
  }
</script>
