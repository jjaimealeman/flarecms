---
import Layout from '../../layouts/Layout.astro'
import { competitors, flareScores, scoreLabels, categoryLabels } from '../../data/comparison'

const scoreKeys = Object.keys(scoreLabels) as (keyof typeof flareScores)[]

// Color map for CMS entries
const colorMap: Record<string, { bg: string; text: string; border: string; badge: string }> = {
  blue: { bg: 'bg-blue-500/10', text: 'text-blue-400', border: 'border-blue-500/30', badge: 'bg-blue-500/15 text-blue-400 border-blue-500/30' },
  orange: { bg: 'bg-orange-500/10', text: 'text-orange-400', border: 'border-orange-500/30', badge: 'bg-orange-500/15 text-orange-400 border-orange-500/30' },
  purple: { bg: 'bg-purple-500/10', text: 'text-purple-400', border: 'border-purple-500/30', badge: 'bg-purple-500/15 text-purple-400 border-purple-500/30' },
  indigo: { bg: 'bg-indigo-500/10', text: 'text-indigo-400', border: 'border-indigo-500/30', badge: 'bg-indigo-500/15 text-indigo-400 border-indigo-500/30' },
  teal: { bg: 'bg-teal-500/10', text: 'text-teal-400', border: 'border-teal-500/30', badge: 'bg-teal-500/15 text-teal-400 border-teal-500/30' },
  emerald: { bg: 'bg-emerald-500/10', text: 'text-emerald-400', border: 'border-emerald-500/30', badge: 'bg-emerald-500/15 text-emerald-400 border-emerald-500/30' },
  red: { bg: 'bg-red-500/10', text: 'text-red-400', border: 'border-red-500/30', badge: 'bg-red-500/15 text-red-400 border-red-500/30' },
}
---

<Layout title="CMS Comparison" description="Compare Flare CMS with Payload, TinaCMS, Keystatic, StudioCMS, CloudCannon, Storyblok, and Sanity.">
  <div class="max-w-7xl mx-auto px-6 pt-16 pb-24">

    <!-- Header -->
    <header class="text-center mb-20">
      <span class="text-xs text-flare-400 uppercase tracking-widest font-medium">Comparison</span>
      <h1 class="mt-3 text-4xl sm:text-5xl font-heading font-bold tracking-tight">
        How Flare CMS compares
      </h1>
      <p class="mt-4 text-lg text-slate-400 max-w-2xl mx-auto">
        The only self-hosted, open-source CMS purpose-built for the Astro + Cloudflare Workers stack. See how we compare to 7 popular alternatives.
      </p>
    </header>

    <!-- Overview Grid -->
    <section class="mb-24">
      <h2 class="text-2xl font-heading font-bold tracking-tight mb-8">At a glance</h2>

      <!-- Desktop comparison table -->
      <div class="hidden lg:block overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-slate-800">
              <th class="text-left py-3 px-4 font-medium text-slate-400 w-40">CMS</th>
              <th class="text-center py-3 px-2 font-medium text-slate-400">Open Source</th>
              <th class="text-center py-3 px-2 font-medium text-slate-400">Self-Hosted</th>
              <th class="text-center py-3 px-2 font-medium text-slate-400">Edge Native</th>
              <th class="text-center py-3 px-2 font-medium text-slate-400">Astro</th>
              <th class="text-left py-3 px-4 font-medium text-slate-400">Database</th>
              <th class="text-left py-3 px-4 font-medium text-slate-400">Media</th>
              <th class="text-left py-3 px-4 font-medium text-slate-400">Pricing</th>
            </tr>
          </thead>
          <tbody>
            <!-- Flare CMS row (highlighted) -->
            <tr class="border-b border-flare-500/20 bg-flare-500/5">
              <td class="py-3 px-4 font-semibold text-flare-400">
                Flare CMS
              </td>
              <td class="text-center py-3 px-2"><span class="text-emerald-400">✓</span></td>
              <td class="text-center py-3 px-2"><span class="text-emerald-400">✓</span></td>
              <td class="text-center py-3 px-2"><span class="text-emerald-400">✓</span></td>
              <td class="text-center py-3 px-2"><span class="text-emerald-400">Native</span></td>
              <td class="py-3 px-4 text-slate-300">D1 (built-in)</td>
              <td class="py-3 px-4 text-slate-300">R2 (built-in)</td>
              <td class="py-3 px-4 text-cyan-400">Free (MIT)</td>
            </tr>
            {competitors.map((cms) => (
              <tr class="border-b border-slate-800/50 hover:bg-slate-800/20 transition-colors">
                <td class="py-3 px-4">
                  <a href={`/comparison/${cms.slug}`} class:list={['font-medium hover:underline', colorMap[cms.color]?.text || 'text-slate-200']}>
                    {cms.name}
                  </a>
                </td>
                <td class="text-center py-3 px-2">
                  {cms.openSource
                    ? <span class="text-emerald-400">✓</span>
                    : <span class="text-slate-600">✗</span>
                  }
                </td>
                <td class="text-center py-3 px-2">
                  {cms.selfHosted
                    ? <span class="text-emerald-400">✓</span>
                    : <span class="text-slate-600">✗</span>
                  }
                </td>
                <td class="text-center py-3 px-2">
                  {cms.cloudflareNative
                    ? <span class="text-emerald-400">✓</span>
                    : <span class="text-slate-600">✗</span>
                  }
                </td>
                <td class="text-center py-3 px-2 text-slate-400 capitalize">{cms.astroIntegration}</td>
                <td class="py-3 px-4 text-slate-400">{cms.details.database.split('.')[0]}</td>
                <td class="py-3 px-4 text-slate-400">{cms.details.media.split('.')[0]}</td>
                <td class="py-3 px-4 text-slate-400">{cms.pricing.split('.')[0]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Mobile cards -->
      <div class="lg:hidden space-y-4">
        <!-- Flare CMS card -->
        <div class="rounded-xl border-2 border-flare-500/30 bg-flare-500/5 p-5">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-2xl">🔥</span>
            <div>
              <div class="font-semibold text-flare-400">Flare CMS</div>
              <div class="text-xs text-slate-500">Edge-native · Open Source · Self-hosted</div>
            </div>
          </div>
          <div class="grid grid-cols-3 gap-3 text-xs">
            <div class="text-center p-2 rounded bg-slate-800/50">
              <div class="text-emerald-400 font-medium">D1</div>
              <div class="text-slate-500">Database</div>
            </div>
            <div class="text-center p-2 rounded bg-slate-800/50">
              <div class="text-emerald-400 font-medium">R2</div>
              <div class="text-slate-500">Media</div>
            </div>
            <div class="text-center p-2 rounded bg-slate-800/50">
              <div class="text-cyan-400 font-medium">Free</div>
              <div class="text-slate-500">MIT License</div>
            </div>
          </div>
        </div>
        {competitors.map((cms) => (
          <a href={`/comparison/${cms.slug}`} class="block rounded-xl border border-slate-800 bg-slate-800/30 p-5 hover:border-slate-700 transition-colors">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-2xl">{cms.logo}</span>
              <div>
                <div class:list={['font-semibold', colorMap[cms.color]?.text || 'text-slate-200']}>{cms.name}</div>
                <div class="text-xs text-slate-500">
                  {cms.openSource ? 'Open Source' : 'Proprietary'} · {cms.selfHosted ? 'Self-hosted' : 'Cloud only'}
                </div>
              </div>
            </div>
            <p class="text-sm text-slate-400 line-clamp-2">{cms.tagline}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Score Comparison Chart -->
    <section class="mb-24">
      <h2 class="text-2xl font-heading font-bold tracking-tight mb-3">Feature scores</h2>
      <p class="text-slate-400 mb-8 text-sm">Rated 1–5 across key dimensions. Higher is better.</p>

      <div class="space-y-6">
        {scoreKeys.map((key) => (
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-medium text-slate-300">{scoreLabels[key]}</span>
              <span class="text-xs text-flare-400 font-mono">{flareScores[key]}/5</span>
            </div>
            <!-- Flare bar -->
            <div class="relative h-3 rounded-full bg-slate-800 mb-1.5">
              <div
                class="absolute inset-y-0 left-0 rounded-full bg-gradient-to-r from-flare-500 to-flare-400"
                style={`width: ${flareScores[key] * 20}%`}
              />
            </div>
            <!-- Competitor bars (smaller) -->
            <div class="space-y-1">
              {competitors.map((cms) => (
                <div class="flex items-center gap-2">
                  <span class="text-[10px] text-slate-500 w-24 truncate">{cms.name}</span>
                  <div class="flex-1 relative h-1.5 rounded-full bg-slate-800/50">
                    <div
                      class:list={['absolute inset-y-0 left-0 rounded-full opacity-60', `bg-${cms.color}-500`]}
                      style={`width: ${cms.scores[key] * 20}%`}
                    />
                  </div>
                  <span class="text-[10px] text-slate-600 w-6 text-right font-mono">{cms.scores[key]}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Why Flare -->
    <section class="mb-24">
      <div class="rounded-2xl border border-flare-500/20 bg-gradient-to-br from-flare-500/5 to-transparent p-8 sm:p-12">
        <h2 class="text-2xl sm:text-3xl font-heading font-bold tracking-tight mb-4">
          Why choose Flare CMS?
        </h2>
        <p class="text-slate-400 mb-8 max-w-2xl">
          Flare CMS is the only headless CMS that combines all three: open-source self-hosting,
          native Cloudflare Workers deployment, and purpose-built Astro integration.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-lg bg-flare-500/20 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-flare-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" /><path d="M2 12h20" /><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
              </svg>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-200">Zero Cold Starts</div>
              <div class="text-xs text-slate-500 mt-1">Runs on Cloudflare Workers across 330+ locations globally.</div>
            </div>
          </div>
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-lg bg-cyan-500/20 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <ellipse cx="12" cy="5" rx="9" ry="3" /><path d="M3 5V19A9 3 0 0 0 21 19V5" /><path d="M3 12A9 3 0 0 0 21 12" />
              </svg>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-200">All-in-One Storage</div>
              <div class="text-xs text-slate-500 mt-1">D1 database, R2 media, KV cache — no external services.</div>
            </div>
          </div>
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-lg bg-emerald-500/20 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
              </svg>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-200">Your Data, Your Servers</div>
              <div class="text-xs text-slate-500 mt-1">Self-hosted and open source. No vendor lock-in.</div>
            </div>
          </div>
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-lg bg-amber-500/20 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" />
              </svg>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-200">Astro-First Frontend</div>
              <div class="text-xs text-slate-500 mt-1">SSR on Cloudflare Pages with typed API client.</div>
            </div>
          </div>
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-lg bg-purple-500/20 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="9" rx="1" /><rect x="14" y="3" width="7" height="5" rx="1" /><rect x="14" y="12" width="7" height="9" rx="1" /><rect x="3" y="16" width="7" height="5" rx="1" />
              </svg>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-200">Built-in Admin UI</div>
              <div class="text-xs text-slate-500 mt-1">Rich text editor, media library, and user management.</div>
            </div>
          </div>
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-lg bg-rose-500/20 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" /><path d="M14.31 8l5.74 9.94M9.69 8h11.48M7.38 12l5.74-9.94M9.69 16L3.95 6.06M14.31 16H2.83M16.62 12l-5.74 9.94" />
              </svg>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-200">Free Forever</div>
              <div class="text-xs text-slate-500 mt-1">MIT licensed. Cloudflare free tier covers most sites.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Individual Comparison Links -->
    <section>
      <h2 class="text-2xl font-heading font-bold tracking-tight mb-3">Detailed comparisons</h2>
      <p class="text-slate-400 mb-8 text-sm">Deep-dive into how Flare CMS stacks up against each alternative.</p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {competitors.map((cms) => {
          const colors = colorMap[cms.color]
          return (
            <a
              href={`/comparison/${cms.slug}`}
              class="group rounded-xl border border-slate-800 bg-slate-800/30 p-5 hover:border-slate-700 hover:bg-slate-800/50 transition-all"
            >
              <div class="flex items-center gap-3 mb-3">
                <span class="text-2xl">{cms.logo}</span>
                <div>
                  <div class:list={['font-semibold group-hover:underline', colors?.text || 'text-slate-200']}>
                    {cms.name}
                  </div>
                  <div class:list={['inline-block text-[10px] px-1.5 py-0.5 rounded-full border mt-1', colors?.badge || 'bg-slate-700 text-slate-400 border-slate-600']}>
                    {categoryLabels[cms.category]}
                  </div>
                </div>
              </div>
              <p class="text-xs text-slate-500 leading-relaxed line-clamp-2">{cms.tagline}</p>
              <div class="mt-3 flex items-center gap-1 text-xs text-slate-600 group-hover:text-slate-400 transition-colors">
                View comparison
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          )
        })}
      </div>
    </section>

  </div>
</Layout>
