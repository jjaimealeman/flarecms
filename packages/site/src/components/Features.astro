  .flow-icon-emerald { color: #34d399; }

  /* Storage group */
  .flow-storage-group {
    position: absolute;
    z-index: 3;
    /* Center horizontally on left value, vertically center on the 30% line */
    top: 30%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
  }

  .flow-storage-bubble {
