  /* Single animated dot */
  .flow-single-dot {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #60a5fa;
    box-shadow: 0 0 10px rgba(96, 165, 250, 0.8);
    z-index: 2;
    pointer-events: none;
    animation: flow-loop 8s linear infinite;
  }

  /* Dot travels: Browser → Website → CMS → Storage → (down) → return left → (up) → Browser
     Percentages match the node positions */
  @keyframes flow-loop {
    0%   { left: 10%; top: 30%; background: #60a5fa; box-shadow: 0 0 10px rgba(96, 165, 250, 0.8); }
    12%  { left: 35%; top: 30%; background: #818cf8; box-shadow: 0 0 10px rgba(129, 140, 248, 0.8); }
    25%  { left: 58%; top: 30%; background: var(--color-flare-500); box-shadow: 0 0 10px rgba(246, 130, 31, 0.8); }
    38%  { left: 84%; top: 30%; background: #34d399; box-shadow: 0 0 10px rgba(52, 211, 153, 0.8); }
    46%  { left: 84%; top: 85%; background: #22d3ee; box-shadow: 0 0 10px rgba(34, 211, 238, 0.8); }
    80%  { left: 10%; top: 85%; }
    92%  { left: 10%; top: 30%; background: #60a5fa; box-shadow: 0 0 10px rgba(96, 165, 250, 0.8); }
    100% { left: 10%; top: 30%; }
  }

  /* Node glow — CSS animations synced to same 8s loop as dot */
  .flow-node-icon[data-step="0"] { animation: flow-glow-0 8s linear infinite; }
  .flow-node-icon[data-step="1"] { animation: flow-glow-1 8s linear infinite; }
  .flow-node-icon[data-step="2"] { animation: flow-glow-2 8s linear infinite; }
  .flow-storage-item:nth-child(1) .flow-storage-icon { animation: flow-glow-3a 8s linear infinite; }
  .flow-storage-item:nth-child(2) .flow-storage-icon { animation: flow-glow-3b 8s linear infinite; }
  .flow-storage-item:nth-child(3) .flow-storage-icon { animation: flow-glow-3c 8s linear infinite; }
  .flow-storage-bubble { animation: flow-glow-bubble 8s linear infinite; }

  @keyframes flow-glow-0 {
    0%, 8% { box-shadow: 0 0 14px currentColor; transform: scale(1.1); }
    12%, 88% { box-shadow: none; transform: scale(1); }
    92%, 100% { box-shadow: 0 0 14px currentColor; transform: scale(1.1); }
  }
  @keyframes flow-glow-1 {
    0%, 10% { box-shadow: none; transform: scale(1); }
    12%, 16% { box-shadow: 0 0 14px currentColor; transform: scale(1.1); }
    20%, 100% { box-shadow: none; transform: scale(1); }
  }
  @keyframes flow-glow-2 {
    0%, 23% { box-shadow: none; transform: scale(1); }
    25%, 29% { box-shadow: 0 0 14px currentColor; transform: scale(1.1); }
    33%, 100% { box-shadow: none; transform: scale(1); }
  }
  /* D1 — first to fire */
  @keyframes flow-glow-3a {
    0%, 36% { box-shadow: none; transform: scale(1); }
    38%, 42% { box-shadow: 0 0 14px currentColor; transform: scale(1.1); }
    46%, 100% { box-shadow: none; transform: scale(1); }
  }
  /* R2 — 1% later (~80ms) */
  @keyframes flow-glow-3b {
    0%, 37% { box-shadow: none; transform: scale(1); }
