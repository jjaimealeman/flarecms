---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Changelog">
  <div class="max-w-3xl mx-auto px-6 pt-12 pb-20">
    <header class="mb-12">
      <h1 class="text-4xl font-sans font-bold tracking-tight">Changelog</h1>
      <p class="mt-2 text-slate-400">What's new in Flare CMS.</p>
    </header>

    <div class="space-y-8">
      <article class="relative pl-8 border-l-2 border-flare-500/30">
        <div class="absolute left-[-9px] top-1 w-4 h-4 rounded-full bg-flare-500 border-4 border-slate-900"></div>
        <div class="flex items-center gap-3 mb-2">
          <span class="text-sm font-sans font-semibold text-flare-400">v1.0.0</span>
          <time class="text-xs text-slate-500">March 2, 2026</time>
        </div>
        <h3 class="font-sans font-semibold text-slate-50 mb-2">Initial Release</h3>
        <ul class="text-sm text-slate-400 space-y-1">
          <li>Forked from SonicJS v2.8.0 and rebranded as Flare CMS</li>
          <li>Monorepo structure with pnpm workspaces (core, cms, site)</li>
          <li>Renamed API: createFlareApp, FlareConfig, FlareApp</li>
          <li>Admin UI rebranded from SonicJS to Flare CMS</li>
          <li>GitHub Actions CI/CD — auto-deploy on push to main</li>
          <li>Custom domains: flarecms.dev + admin.flarecms.dev</li>
          <li>Astro 5 SSR frontend on Cloudflare Pages</li>
        </ul>
      </article>
    </div>
  </div>
</Layout>
